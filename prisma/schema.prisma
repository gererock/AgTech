generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DRIVER
  MACHINE_OPERATOR
}

enum TripStatus {
  PENDING
  IN_TRANSIT
  COMPLETED
}

enum SyncEntityType {
  TRIP
  WORK_ORDER
}

enum SyncStatus {
  SUCCESS
  FAILED
}

enum InventoryItemType {
  FUEL
  CHEMICAL
  AGRO
}

model Lot {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @unique
  hectares   Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model InventoryItem {
  id             String             @id @default(uuid()) @db.Uuid
  name           String
  type           InventoryItemType
  unit           String
  quantity       Float              @default(0)
  minQuantity    Float              @default(0)
  active         Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  fuelTrips      Trip[]             @relation("TripFuel")
  agroTrips      Trip[]             @relation("TripAgro")
  fuelWorkOrders WorkOrder[]        @relation("WorkOrderFuel")
  chemicals      WorkOrderChemical[]
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tripsAsDriver        Trip[]      @relation("TripDriver")
  workOrdersAsOperator WorkOrder[] @relation("WorkOrderOperator")
}

model Customer {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  email           String?
  phone           String?
  address         String?
  documentNumber  String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workOrders      WorkOrder[] @relation("WorkOrderCustomer")
}

model Machinery {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  type            String?
  brand           String?
  identifier      String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workOrders      WorkOrder[] @relation("WorkOrderMachinery")
}

model Trip {
  id              String     @id @default(uuid()) @db.Uuid
  truck           String?
  licensePlate    String
  driverId        String?    @db.Uuid
  driver          User?      @relation("TripDriver", fields: [driverId], references: [id], onDelete: SetNull)
  driverName      String
  origin          String     @default("Sin informar")
  destination     String     @default("Sin informar")
  product         String
  estimatedKg     Int
  loadedKg        Int?
  destinationKg   Int?
  fuelLiters      Float?     @default(0)
  fuelItemId      String?    @db.Uuid
  fuelItem        InventoryItem? @relation("TripFuel", fields: [fuelItemId], references: [id], onDelete: SetNull)
  agroItemId      String?    @db.Uuid
  agroItem        InventoryItem? @relation("TripAgro", fields: [agroItemId], references: [id], onDelete: SetNull)
  status          TripStatus @default(PENDING)
  clientCreatedAt DateTime?
  syncedAt        DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([driverId])
  @@index([status])
  @@index([updatedAt])
}

model WorkOrder {
  id                String   @id @default(uuid()) @db.Uuid
  machineryId       String?  @db.Uuid
  machineryCatalog  Machinery? @relation("WorkOrderMachinery", fields: [machineryId], references: [id], onDelete: SetNull)
  machinery         String
  operatorId        String?  @db.Uuid
  operator          User?    @relation("WorkOrderOperator", fields: [operatorId], references: [id], onDelete: SetNull)
  operatorName      String
  hectaresWorked    Float
  fuelLiters        Float
  fuelItemId        String?   @db.Uuid
  fuelItem          InventoryItem? @relation("WorkOrderFuel", fields: [fuelItemId], references: [id], onDelete: SetNull)
  plot              String   @default("Sin informar")
  customerId        String?  @db.Uuid
  customerCatalog   Customer? @relation("WorkOrderCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  customer          String   @default("Sin informar")
  chemicals         WorkOrderChemical[]
  clientCreatedAt   DateTime?
  syncedAt          DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([operatorId])
  @@index([machineryId])
  @@index([customerId])
  @@index([updatedAt])
}

model WorkOrderChemical {
  id              String         @id @default(uuid()) @db.Uuid
  workOrderId     String?        @db.Uuid
  workOrder       WorkOrder?     @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  inventoryItemId String?        @db.Uuid
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  product         String
  quantity        Float
  unit            String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([workOrderId])
  @@index([inventoryItemId])
}

model SyncLog {
  id         String         @id @default(uuid()) @db.Uuid
  entityType SyncEntityType
  entityId   String?        @db.Uuid
  status     SyncStatus
  message    String?
  payload    Json?
  createdAt  DateTime       @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}
